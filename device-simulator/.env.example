# Địa chỉ broker MQTT (mosquitto chạy qua docker-compose, expose ra localhost:1883)
MQTT_HOST=mqtt://localhost:1883

# Định danh & thông tin xác thực của thiết bị (phải khớp với mosquitto/config/password_file
# và acl.conf — xem mosquitto/config/init-credentials.sh)
DEVICE_ID=AQ-DEVICE-01
MQTT_USERNAME=AQ-DEVICE-01
MQTT_PASSWORD=device01pass

# Chu kỳ publish dữ liệu (ms)
PUBLISH_INTERVAL_MS=5000

# Kịch bản giả lập: normal | polluted | rush_hour
# - normal: chỉ số ô nhiễm dao động ở mức an toàn quanh baseline
# - polluted: baseline cao, mô phỏng khu vực ô nhiễm nặng (để test cảnh báo)
# - rush_hour: baseline tăng dần rồi giảm dần, mô phỏng giờ cao điểm giao thông
SCENARIO=normal
